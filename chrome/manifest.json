{
  "manifest_version": 3,
  "name": "OpenWebUI Omnibox",
  "version": "1.0.0",
  "description": "Access OpenWebUI directly from the address bar",
  "background": {
    "service_worker": "background.js"
  },
  "omnibox": {
    "keyword": "o"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  }
}
